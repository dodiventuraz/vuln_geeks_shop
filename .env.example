# Vuln Geeks Shop — contoh environment. Salin ke `.env` dan sesuaikan bila perlu.
# CATATAN: .env asli TIDAK di-commit (lihat .gitignore).

APP_ENV=dev
DEBUG=false

# Bind server — REQ-S1: default localhost. JANGAN set 0.0.0.0 di luar container.
HOST=127.0.0.1
PORT=8000

# Database (SQLAlchemy DSN untuk PostgreSQL)
DATABASE_URL=postgresql+psycopg2://vuln:vuln@localhost:5432/vulnshop

# Session cookie (Starlette SessionMiddleware) — lab only
SESSION_SECRET=lab-only-insecure-session-secret-change-me

# File toggle kerentanan
CHALLENGES_FILE=challenges.yaml
